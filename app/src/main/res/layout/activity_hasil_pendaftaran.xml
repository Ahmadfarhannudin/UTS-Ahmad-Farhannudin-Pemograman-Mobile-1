<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <Space android:layout_width="0dp" android:layout_height="48dp"/>

            <!-- Success Icon -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp">
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_success_bg"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#4CAF50"/>
            </FrameLayout>

            <Space android:layout_width="0dp" android:layout_height="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendaftaran Berhasil! 🎉"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Anda telah berhasil didaftarkan"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <Space android:layout_width="0dp" android:layout_height="32dp"/>

            <!-- Card Hasil -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detail Pendaftaran"
                        android:textColor="@color/accent_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <!-- Nama -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <View android:layout_width="4dp" android:layout_height="40dp" android:background="@drawable/divider_accent" android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama" android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvNamaHasil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <View android:layout_width="4dp" android:layout_height="40dp" android:background="@drawable/divider_accent" android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvEmailHasil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- HP -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <View android:layout_width="4dp" android:layout_height="40dp" android:background="@drawable/divider_accent" android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nomor HP" android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvHpHasil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Jenis Kelamin -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <View android:layout_width="4dp" android:layout_height="40dp" android:background="@drawable/divider_accent" android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jenis Kelamin" android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvJenisKelaminHasil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Seminar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="4dp" android:layout_height="40dp" android:background="@drawable/divider_accent" android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seminar Dipilih" android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvSeminarHasil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/accent_primary" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space android:layout_width="0dp" android:layout_height="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKembaliUtama"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Kembali ke Halaman Utama"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/accent_primary"
                app:cornerRadius="16dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Space android:layout_width="0dp" android:layout_height="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
