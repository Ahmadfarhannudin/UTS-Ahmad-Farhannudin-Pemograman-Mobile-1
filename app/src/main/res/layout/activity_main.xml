<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View android:layout_width="280dp" android:layout_height="280dp" android:layout_gravity="top|end" android:layout_marginTop="-60dp" android:layout_marginEnd="-60dp" android:background="@drawable/blob_gradient_1" android:alpha="0.4"/>
    <View android:layout_width="220dp" android:layout_height="220dp" android:layout_gravity="bottom|start" android:layout_marginBottom="-40dp" android:layout_marginStart="-40dp" android:background="@drawable/blob_gradient_2" android:alpha="0.35"/>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

            <Space android:layout_width="0dp" android:layout_height="60dp"/>

            <!-- Header Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="28dp" android:gravity="center">
                    <FrameLayout android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="center">
                        <View android:layout_width="80dp" android:layout_height="80dp" android:background="@drawable/logo_bg_glow"/>
                        <androidx.appcompat.widget.AppCompatImageView android:layout_width="44dp" android:layout_height="44dp" android:layout_gravity="center" android:src="@drawable/ic_logo_bolt" app:tint="@color/accent_primary"/>
                    </FrameLayout>
                    <Space android:layout_width="0dp" android:layout_height="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seminar Registration App" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daftarkan dirimu sekarang!" android:textColor="@color/text_muted" android:textSize="14sp" android:layout_marginTop="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space android:layout_width="0dp" android:layout_height="20dp"/>

            <!-- Welcome Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                        <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_accent_bg"/>
                        <androidx.appcompat.widget.AppCompatImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_gravity="center" android:src="@drawable/ic_person" app:tint="@color/accent_primary"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:id="@+id/tvWelcome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Halo, User! 👋" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="user@email.com" android:textColor="@color/text_muted" android:textSize="13sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space android:layout_width="0dp" android:layout_height="20dp"/>

            <!-- Info Seminar -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seminar Tersedia" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                    <Space android:layout_width="0dp" android:layout_height="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI &amp; Machine Learning" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cybersecurity 2025" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile Development" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Science &amp; Analytics" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dan masih banyak lagi..." android:textColor="@color/accent_primary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Space android:layout_width="0dp" android:layout_height="28dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btnDaftarSeminar" android:layout_width="match_parent" android:layout_height="56dp" android:text="🎓  Daftar Seminar" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF" app:backgroundTint="@color/accent_primary" app:cornerRadius="16dp" app:elevation="0dp" style="@style/Widget.MaterialComponents.Button"/>

            <Space android:layout_width="0dp" android:layout_height="32dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
